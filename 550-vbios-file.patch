+
+NV_STATUS NV_API_CALL nv_acpi_rom_from_file(
+    nv_state_t *nv,
+    NvU32 *pInData,
+    NvU32 *pOutData
+)
+{
+    uint32_t offset, length;
+
+    offset = pInData[0];
+    length = pInData[1];
+
+    if(cached_vbios == NULL) {
+        nv_printf(NV_DBG_ERRORS,
+              "NVRM: %s: VBIOS file is not loaded!\n", __FUNCTION__);
+
+        return NV_ERR_INVALID_ARGUMENT;
+    }
+
+
+    if(cached_vbios_sz < length + offset)
+    {
+        nv_printf(NV_DBG_ERRORS,
+              "NVRM: %s: Mismatched VBIOS size - buffer overflow!\n", __FUNCTION__);
+
+        return NV_ERR_INVALID_ARGUMENT;
+    }
+
+    memcpy(pOutData, cached_vbios + offset, length);
+
+    return NV_OK; 
+}
