+static void nv_acpi_init_vbios_file(void)
+{
+    const struct firmware *firmware;
+
+    nv_printf(NV_DBG_INFO,
+          "NVRM: %s: Experimental - attempting to load the VBIOS from file.\n", __FUNCTION__);
+
+    if(request_firmware(&firmware, NV_vbios_file, NULL) != 0)
+    {
+        nv_printf(NV_DBG_ERRORS,
+              "NVRM: %s: Failed to find the VBIOS file!\n", __FUNCTION__);
+
+        release_firmware(firmware);
+        return;
+    }
+
+    cached_vbios = vmalloc(firmware->size);
+    if(!cached_vbios)
+    {
+        nv_printf(NV_DBG_ERRORS,
+              "NVRM: %s: Failed to allocate memory for the VBIOS!\n", __FUNCTION__);
+        release_firmware(firmware);
+        return;
+    }
+
+    cached_vbios_sz = firmware->size;
+
+    memcpy(cached_vbios, firmware->data, firmware->size);
+
+    release_firmware(firmware);
+}
+
